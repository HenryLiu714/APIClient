{
  "compilerOptions": {
    /* Basic Options */
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "outDir": "./dist",
    // "rootDir": "./src",
    
    /* Strictness - CRITICAL for Result types */
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    
    /* Path Mapping - No more ../../../ imports */
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@repositories/*": ["src/repositories/*"],
      "@types/*": ["src/types/*"]
    },

    /* Prisma & Module Compatibility */
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "sourceMap": true
  },
  "include": ["src/**/*", "prisma.config.ts"],
  "exclude": ["node_modules", "dist"]
}